# Copy to `frontend/.env.local` and fill from Supabase → Settings → API
# (Project URL + anon public / legacy anon key).
#
# If these are empty, the app falls back to lib/supabase/embedded-public-env.ts
# (tutorial project). Set them here to point at your own Supabase project.
#
# Run the app from this folder: `cd frontend && npm run dev`
#
# Optional fallbacks (e.g. some hosts only inject non-public names):
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
